## CBPT ON SPACE - 8 obs
# === CBPT - BAND AVERAGED MEDIAN PSD across trials ( n_obs = 8 )

# --- Fasi ---
phase_names = ["Rest", "Reach", "Grasp", "Pull"]

# --- Bande ---
freq_bands = {'beta_all': (13, 30), 'beta_low': (13, 20), 'beta_high': (20, 30)}

# ------------------------------------------------------------------
# COSTRUZIONE MATRICE: subjects × channels PER OGNI fase e banda
# ------------------------------------------------------------------
SUBJ_BAND = {band: {phase: [] for phase in phase_names} for band in freq_bands}

for subj in EEG_DATA_ALL.keys():
    freqs = eeg_psd_data_dict[subj]['freqs']
    for p, phase in enumerate(phase_names):
        psd_norm = eeg_psd_data_dict[subj]['PSD_norm'][p].T  # ch × freqs
        for band, (fmin, fmax) in freq_bands.items():
            mask = (freqs >= fmin) & (freqs <= fmax)
            band_mean = psd_norm[:, mask].mean(axis=1)
            SUBJ_BAND[band][phase].append(band_mean)

# Conversione in array → subjects × channels
for band in freq_bands:
    for phase in phase_names:
        SUBJ_BAND[band][phase] = np.stack(SUBJ_BAND[band][phase], axis=0)

# ------------------------------------------------------------------
# DEFINIZIONE DELLE COPPIE DI CONFRONTO
# ------------------------------------------------------------------
#phase_pairs = list(itertools.combinations(range(len(phase_names)), 2))
phase_pairs = [(0, p) for p in range(1, len(phase_names))]
extra_pairs = ['Rest_vs_ReachGrasp']  # nuova condizione
ALL_RESULTS_BANDS = {}

# ------------------------------------------------------------------
# CBPT
# ------------------------------------------------------------------
for band in freq_bands:
    ALL_RESULTS_BANDS[band] = {}

    # Ciclo sui pair classici
    for (p1, p2) in phase_pairs:
        A = phase_names[p1]
        B = phase_names[p2]
        pair_name = f"{A}_vs_{B}"
        X_diff = SUBJ_BAND[band][A] - SUBJ_BAND[band][B]

        pval = 0.001
        n_obs = X_diff.shape[0]
        df = n_obs - 1
        thresh = scipy.stats.t.ppf(1 - pval/2, df)

        print(f"\nRunning CBPT: {pair_name}, band={band}")
        T_obs, clusters, p_vals, H0 = permutation_cluster_1samp_test(
            X=X_diff,
            adjacency=adjacency,
            threshold=thresh,
            n_permutations=300,
            tail=0,
            out_type='mask',
            verbose=False
        )

        ALL_RESULTS_BANDS[band][pair_name] = {
            "T_obs": T_obs,
            "clusters": clusters,
            "p_values": p_vals
        }

    # Ciclo sul confronto extra: Rest vs (Reach+Grasp)
    A = 'Rest'
    B_mean = (SUBJ_BAND[band]['Reach'] + SUBJ_BAND[band]['Grasp']) / 2
    X_diff = SUBJ_BAND[band][A] - B_mean
    pair_name = 'Rest_vs_ReachGrasp'

    pval = 0.01
    n_obs = X_diff.shape[0]
    df = n_obs - 1
    thresh = scipy.stats.t.ppf(1 - pval/2, df)

    print(f"\nRunning CBPT: {pair_name}, band={band}")
    T_obs, clusters, p_vals, H0 = permutation_cluster_1samp_test(
        X=X_diff,
        adjacency=adjacency,
        threshold=thresh,
        n_permutations=300,
        tail=0,
        out_type='mask',
        verbose=False
    )

    ALL_RESULTS_BANDS[band][pair_name] = {
        "T_obs": T_obs,
        "clusters": clusters,
        "p_values": p_vals
    }

print("\nDone.")


for band in ALL_RESULTS_BANDS.keys():
    # --- Raccogli solo cluster significativi della banda ---
    sig_clusters = []
    cluster_titles = []
    T_clusters = []

    for pair_name, res in ALL_RESULTS_BANDS[band].items():
        T_obs = res['T_obs']
        clusters = res['clusters']
        p_values = res['p_values']

        for c_idx, cluster_mask in enumerate(clusters):
            p_val = p_values[c_idx]
            if p_val >= 0.05:
                continue  # solo significativi

            # riduci a canali
            if cluster_mask.ndim > 1:
                ch_mask = cluster_mask.any(axis=0)
            else:
                ch_mask = cluster_mask

            ch_indices = np.where(ch_mask)[0]
            T_plot = np.zeros_like(T_obs)
            T_plot[ch_indices] = T_obs[ch_indices]

            sig_clusters.append(T_plot)
            cluster_titles.append(f"{pair_name} | Cluster {c_idx} (p={p_val:.3f})")
            T_clusters.append(T_plot)

    if len(sig_clusters) == 0:
        print(f"No significant clusters for band {band}")
        continue

    # --- Trova vmin/vmax assoluti per la colorbar ---
    all_data = np.stack(T_clusters, axis=0)
    vmin = all_data.min()
    vmax = all_data.max()
    norm = mpl.colors.Normalize(vmin=vmin, vmax=vmax)
    cmap = plt.get_cmap('RdBu_r')

    # --- Crea figura con subplot affiancati ---
    n = len(sig_clusters)
    fig, axes = plt.subplots(1, n, figsize=(5*n, 5))
    if n == 1:
        axes = [axes]  # per uniformità

    fig.suptitle(f"Significant clusters | Band: {band}", fontsize=16)

    for ax, T_plot, title in zip(axes, sig_clusters, cluster_titles):

        mask_plot = (T_plot != 0).astype(int)

        cmap_bin = mpl.colors.ListedColormap(['lightgray', '#0077CC'])
        norm_bin = mpl.colors.Normalize(vmin=0, vmax=1)

        im, _ = mne.viz.plot_topomap(
            mask_plot,
            info,
            cmap=cmap_bin,
            cnorm=norm_bin,
            contours=0,
            sensors=True,
            axes=ax,
            show=False,
            names=ch_names
        )
        ax.set_title(title, fontsize=10)

    # --- Colorbar orizzontale sotto tutti i subplot ---
    cbar_ax = fig.add_axes([0.95, 0.15, 0.015, 0.7])  # left, bottom, width, height
    cmap_bin = mpl.colors.ListedColormap(['lightgray', '#0077CC'])
    norm_bin = mpl.colors.Normalize(vmin=0, vmax=1)
    cbar = mpl.colorbar.ColorbarBase(cbar_ax, cmap=cmap_bin, norm=norm_bin, ticks=[0.25, 0.75])
    cbar.set_ticklabels(['Not significant', 'Significant'])
    cbar.set_label("Significance mask")

    plt.tight_layout()
