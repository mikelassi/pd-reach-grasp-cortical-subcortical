""
Refactored and documented version of the original data import and processing pipeline.

This module:
- Loads EEG and LFP .set (EEGLAB) files and accompanying MATLAB trial structures.
- Aligns trials by trimming REST sections to a global minimal REST length across
  the subject's blocks (zero-padding/trimming approach retained).
- Applies per-block trial exclusions (provided in a dictionary).
- Aggregates and saves structured data to pickles.
- Loads various PSD MAT files (hdf5storage) and converts them to pickles,
  computing trial-wise arrays and medians per phase.
- Includes a simple plotting sanity-check function for the LFP PSD pickle.

Notes:
- The behavioural logic (which files, how to align, and how to trim) is preserved.
- Paths and subject lists are parameters (not hard-coded) to make the functions reusable.
- Logging is used to provide progress updates instead of many print() calls.
"""

from pathlib import Path
import os
import logging
from typing import Dict, List, Any, Optional, Tuple
import pickle
import warnings

import numpy as np
from scipy.io import loadmat
import hdf5storage
import mne
import matplotlib.pyplot as plt
from itertools import combinations

# Configure basic logging
logging.basicConfig(level=logging.INFO, format="%(asctime)s %(levelname)s: %(message)s")


# ------------------------
# Helper types
# ------------------------
TrialArray = np.ndarray
BlockDict = Dict[str, Any]
SubjectDict = Dict[str, Any]


# ------------------------
# Core functions
# ------------------------
def find_files_for_subject(base_path: Path, subject_id: str) -> Tuple[Path, Path, List[Path], List[Path], List[Path], List[Path]]:
    """
    Given base_path and subject_id, return paths to EEG/LFP set directories and lists of .set/.mat files.

    Returns:
        (set_path_EEG, set_path_LFP, set_files_EEG, mat_files_EEG, set_files_LFP, mat_files_LFP)
    """
    # Construct relevant directories
    mat_path_EEG = base_path / subject_id / 'Preprocessed_01' / 'EEG_manual'
    mat_path_LFP = base_path / subject_id / 'Preprocessed_02' / 'LFP_01' / 'CONNECTIVITY'
    set_path_EEG = base_path / subject_id / 'Preprocessed_01' / 'EEG_manual'
    set_path_LFP = base_path / subject_id / 'Preprocessed_02' / 'LFP_01'

    # Collect files
    set_files_EEG = sorted([p for p in set_path_EEG.iterdir() if p.suffix == '.set']) if set_path_EEG.exists() else []
    mat_files_EEG = sorted([p for p in mat_path_EEG.iterdir() if p.name.endswith('_EEG_trialsByRegionAndPhase.mat')]) if mat_path_EEG.exists() else []

    set_files_LFP = sorted([p for p in set_path_LFP.iterdir() if p.suffix == '.set']) if set_path_LFP.exists() else []
    mat_files_LFP = sorted([p for p in mat_path_LFP.iterdir() if p.name.endswith('_LFP_trialsByRegionAndPhase_Connectivity.mat')]) if mat_path_LFP.exists() else []

    return set_path_EEG, mat_path_EEG, set_files_EEG, mat_files_EEG, set_files_LFP, mat_files_LFP


def compute_global_min_rest(mat_files_eeg: List[Path], mat_files_lfp: List[Path]) -> Optional[int]:
    """
    Compute the minimal REST length (samples) across provided EEG/LFP mat files.
    We look inside 'EEG_phases' and 'LFP_phases' structures and read the length of the
    first phase, first channel (assumes first phase is REST).
    Returns None if none found.
    """
    rest_lengths_all = []

    # Helper to extract rest lengths from a .mat file based on key
    def _collect_rest_lengths(mat_path: Path, key: str):
        try:
            data = loadmat(str(mat_path), squeeze_me=True, struct_as_record=False)
        except Exception as e:
            logging.warning("Could not load MAT file %s: %s", mat_path, e)
            return
        if key not in data:
            return
        phases_container = data[key]
        for phases in phases_container:
            try:
                # phases[trial_idx][0][0] -> first phase, first channel; measure length
                rest_len = len(phases[0][0])
                rest_lengths_all.append(int(rest_len))
            except Exception:
                # Skip malformed entries
                continue

    for mf in mat_files_eeg:
        _collect_rest_lengths(mf, 'EEG_phases')

    for mf in mat_files_lfp:
        _collect_rest_lengths(mf, 'LFP_phases')

    if rest_lengths_all:
        return min(rest_lengths_all)
    else:
        return None


def align_trials_to_min_rest(trials: List[TrialArray], phases: List[Any], min_rest_len: int,
                             kinematic: Optional[List[TrialArray]] = None) -> Tuple[List[TrialArray], Optional[List[TrialArray]]]:
    """
    Trim the beginning of each trial so that REST length matches min_rest_len.
    Returns (aligned_trials, aligned_kinematic_or_None)
    - trials: list of arrays shape (channels, time)
    - phases: list of phase structures used to read current rest length
    - min_rest_len: integer minimal rest length computed globally
    - kinematic: optional list of kinematic arrays with same time dimension
    """
    aligned = []
    aligned_kin = [] if kinematic is not None else None

    for idx, trial in enumerate(trials):
        try:
            current_rest_len = len(phases[idx][0][0])
        except Exception:
            # If we cannot read the phase structure, treat as no trim
            current_rest_len = min_rest_len

        if current_rest_len > min_rest_len:
            trim_len = current_rest_len - min_rest_len
            trimmed = trial[:, trim_len:]
            if kinematic is not None:
                ktrim = kinematic[idx][trim_len:]
                aligned_kin.append(ktrim)
        else:
            trimmed = trial
            if kinematic is not None:
                aligned_kin.append(kinematic[idx])
        aligned.append(trimmed)

    return aligned, aligned_kin


def filter_excluded_trials(trials: List[Any], aligned_trials: List[Any], phases: List[Any], kinematics: Optional[List[Any]],
                           exclude_list: List[int]) -> Tuple[List[Any], List[Any], List[Any], Optional[List[Any]]]:
    """
    Remove trials whose 1-based indices are in exclude_list.
    Returns (trials_filtered, aligned_filtered, phases_filtered, kinematics_filtered)
    """
    if not exclude_list:
        return trials, aligned_trials, phases, kinematics

    exclude_set = set(exclude_list)
    trials_f = [trial for idx, trial in enumerate(trials) if (idx + 1) not in exclude_set]
    aligned_f = [trial for idx, trial in enumerate(aligned_trials) if (idx + 1) not in exclude_set]
    phases_f = [ph for idx, ph in enumerate(phases) if (idx + 1) not in exclude_set]
    kin_f = None
    if kinematics is not None:
        kin_f = [k for idx, k in enumerate(kinematics) if (idx + 1) not in exclude_set]
    return trials_f, aligned_f, phases_f, kin_f


def safe_concat(trial_list: List[np.ndarray], axis: int = 1) -> np.ndarray:
    """
    Concatenate trials safely along axis. If list empty, returns empty array.
    """
    if not trial_list:
        return np.empty((0, 0))
    try:
        return np.concatenate(trial_list, axis=axis)
    except Exception as e:
        logging.warning("Concatenation failed: %s", e)
        return np.empty((0, 0))


def load_eeg_and_lfp_for_subject(base_path: Path, subject_id: str, exclude_dict_eeg: Dict[str, Dict[int, List[int]]]) -> Tuple[List[BlockDict], List[BlockDict], List[BlockDict], List[BlockDict]]:
    """
    Load EEG and LFP data for one subject, perform trial alignment and filtering,
    and return structured block lists:
      - subj_eeg_blocks: for EEG->LFP analysis (aligned & filtered)
      - subj_eeg_blocks_EEG2EEG: for EEG->EEG analysis (raw + concatenated)
      - subj_lfp_blocks: for LFP per-block structures
      - short summaries for each (returned as well but left inside returned lists)
    """
    logging.info("Processing subject %s", subject_id)
    set_path_EEG, mat_path_EEG, set_files_EEG, mat_files_EEG, set_files_LFP, mat_files_LFP = find_files_for_subject(base_path, subject_id)

    # If subject-specific removal (wue06 block removed for EEG preprocessing)
    if subject_id == 'wue06':
        if set_files_LFP:
            set_files_LFP = set_files_LFP[:-1]
        if mat_files_LFP:
            mat_files_LFP = mat_files_LFP[:-1]

    # Compute global minimal REST length across blocks
    min_rest_len_global = compute_global_min_rest(mat_files_EEG, mat_files_LFP)
    if min_rest_len_global is None:
        logging.warning("No REST lengths found for subject %s. Alignment will be skipped.", subject_id)
        min_rest_len_global = 0

    subj_eeg_blocks = []
    subj_eeg_blocks_EEG2EEG = []
    subj_lfp_blocks = []

    # --- EEG blocks ---
    for i, set_file in enumerate(set_files_EEG):
        logging.info("[EEG] Loading block %d/%d: %s", i+1, len(set_files_EEG), set_file.name)
        eeg_file = set_file
        # Guard against fewer mat files than set files
        try:
            mat_file = mat_files_EEG[i]
        except IndexError:
            logging.warning("No matching EEG mat file for block %d; skipping block.", i+1)
            continue

        # Load raw EEGLAB file using MNE
        try:
            EEG = mne.io.read_raw_eeglab(str(eeg_file), preload=True, verbose='ERROR')
        except Exception as e:
            logging.warning("Could not load EEG file %s: %s", eeg_file, e)
            continue
        montage_eeg = EEG.get_montage()
        fs = EEG.info['sfreq']
        n_ch = len(EEG.ch_names)

        # Load trial structures from MATLAB file
        try:
            E = loadmat(str(mat_file), squeeze_me=True, struct_as_record=False)
        except Exception as e:
            logging.warning("Could not load mat file %s: %s", mat_file, e)
            continue

        EEG_phases = list(E.get('EEG_phases', []))
        EEG_trials = list(E.get('EEG_trials', []))
        baseline_EEG = E.get('baseline_EEG', None)
        kinematic_trials = list(E.get('kinematic_4EEG_trials', []))

        # Align trials to min REST length
        aligned_EEG_trials, aligned_kinematic_trials = align_trials_to_min_rest(EEG_trials, EEG_phases, min_rest_len_global, kinematic_trials)

        # Filter excluded trials if any (exclude_dict_eeg uses 1-based block keys)
        exclude_trial = exclude_dict_eeg.get(subject_id, {}).get(i+1, [])
        EEG_trials_filtered, aligned_EEG_trials_filtered, EEG_phases_filtered, kinematic_trials_filtered = filter_excluded_trials(
            EEG_trials, aligned_EEG_trials, EEG_phases, kinematic_trials, exclude_trial
        )

        logging.info("[EEG] Block %d: %d trials (after excluding)", i+1, len(aligned_EEG_trials_filtered))

        # Build block dictionaries (keeps both aligned and raw structures where appropriate)
        block_eeg_eeg2eeg = {
            'EEG_raw': EEG,
            'EEG_trials_filtered': EEG_trials_filtered,
            'EEG_all_concat_filtered': safe_concat(EEG_trials_filtered, axis=1),
            'EEG_trials_aligned': aligned_EEG_trials,
            'EEG_phases': EEG_phases,
            'baseline': baseline_EEG,
            'kinematic_trials_filtered_aligned': kinematic_trials_filtered,
            'aligned_kinematic_trials': aligned_kinematic_trials,
            'fs': fs,
            'n_channels': n_ch,
            'chan_names': EEG.ch_names,
            'montage': montage_eeg
        }

        block_eeg = {
            'EEG_raw': EEG,
            'EEG_trials_filtered': EEG_trials_filtered,
            'EEG_all_concat_filtered': safe_concat(EEG_trials_filtered, axis=1),
            'EEG_trials_filtered_aligned': aligned_EEG_trials_filtered,
            'EEG_phases': EEG_phases_filtered,
            'baseline': baseline_EEG,
            'kinematic_trials_filtered_aligned': kinematic_trials_filtered,
            'aligned_kinematic_trials_filtered': aligned_kinematic_trials,
            'fs': fs,
            'n_channels': n_ch,
            'chan_names': EEG.ch_names,
            'montage': montage_eeg
        }

        subj_eeg_blocks_EEG2EEG.append(block_eeg_eeg2eeg)
        subj_eeg_blocks.append(block_eeg)

    # --- LFP blocks ---
    for j, set_file in enumerate(set_files_LFP):
        logging.info("[LFP] Loading block %d/%d: %s", j+1, len(set_files_LFP), set_file.name)
        lfp_file = set_file
        try:
            mat_file = mat_files_LFP[j]
        except IndexError:
            logging.warning("No matching LFP mat file for block %d; skipping block.", j+1)
            continue

        # Load raw LFP EEGLAB file
        try:
            LFP = mne.io.read_raw_eeglab(str(lfp_file), preload=True, verbose='ERROR')
        except Exception as e:
            logging.warning("Could not load LFP file %s: %s", lfp_file, e)
            continue
        fs = LFP.info['sfreq']
        n_ch = len(LFP.ch_names)

        try:
            L = loadmat(str(mat_file), squeeze_me=True, struct_as_record=False)
        except Exception as e:
            logging.warning("Could not load LFP mat file %s: %s", mat_file, e)
            continue

        LFP_phases = list(L.get('LFP_phases', []))
        LFP_trials = list(L.get('LFP_trials', []))
        baseline_LFP = L.get('baseline_LFP', None)

        aligned_LFP_trials, _ = align_trials_to_min_rest(LFP_trials, LFP_phases, min_rest_len_global, None)

        block_lfp = {
            'LFP_raw': LFP,
            'LFP_trials_filtered': LFP_trials,
            'LFP_all_concat_filtered': safe_concat(LFP_trials, axis=1),
            'LFP_trials_filtered_aligned': aligned_LFP_trials,
            'LFP_phases': LFP_phases,
            'baseline': baseline_LFP,
            'fs': fs,
            'n_channels': n_ch,
            'chan_names': LFP.ch_names
        }

        subj_lfp_blocks.append(block_lfp)

    return subj_eeg_blocks, subj_eeg_blocks_EEG2EEG, subj_lfp_blocks


def save_structured_pickles(output_dir: Path, data_map: Dict[str, Any]) -> None:
    """
    Save each item in data_map (name->object) as a pickle file in output_dir.
    """
    output_dir.mkdir(parents=True, exist_ok=True)
    for name, data in data_map.items():
        file_path = output_dir / f"{name}.pkl"
        try:
            with open(file_path, 'wb') as fh:
                pickle.dump(data, fh, protocol=pickle.HIGHEST_PROTOCOL)
            logging.info("Saved %s to %s", name, file_path)
        except Exception as e:
            logging.exception("Failed to save %s to %s: %s", name, file_path, e)


# ------------------------
# PSD MAT -> Pickle Helpers
# ------------------------
def psd_struct_to_dict(mat_file: Path, phase_names: List[str]) -> Dict[str, Any]:
    """
    Convert a MATLAB PSD_STRUCT (hdf5-style) to a Python dict keyed by subject.
    For each subject we create:
      - freqs (cropped to minimum block freq length)
      - PSD_trials (dict phase->array freq x trials)
      - PSD_trials_norm
      - PSD_median (median across trials for each freq)
      - PSD_norm_median
      - freqs_cutted
    """
    mat_data = hdf5storage.loadmat(str(mat_file))
    PSD_STRUCT = mat_data['PSD_STRUCT']
    subject_list = list(PSD_STRUCT.dtype.names)

    data_dict: Dict[str, Any] = {}

    for subj_id in subject_list:
        subj_data = PSD_STRUCT[subj_id][0, 0]
        subj_dict: Dict[str, Any] = {}

        n_blocks = subj_data['block'].shape[1]
        # Find minimal frequency length across blocks
        block_freq_lengths = []
        for f in range(n_blocks):
            freqs_block = np.array(subj_data['block'][0, f]['frequencies']).flatten()
            block_freq_lengths.append(len(freqs_block))
        min_len_block = int(min(block_freq_lengths))

        freqs_orig = np.array(subj_data['block'][0, 0]['frequencies']).flatten()
        subj_freqs = freqs_orig[:min_len_block]
        subj_dict['freqs'] = subj_freqs

        # Collect trials per phase
        trials_per_phase = {phase: [] for phase in phase_names}

        for f in range(n_blocks):
            block = subj_data['block'][0, f]
            n_trials = block['trial'].shape[1]
            for t in range(n_trials):
                trial = block['trial'][0, t]
                for p_idx, phase in enumerate(phase_names):
                    phase_data = trial['phase'][0, p_idx]
                    psd = np.array(phase_data['psd']).flatten()[:min_len_block]
                    psd_norm = np.array(phase_data['psd_norm']).flatten()[:min_len_block]
                    trials_per_phase[phase].append({'PSD': psd, 'PSD_norm': psd_norm})

        # Build arrays and medians
        PSD_trials = {}
        PSD_trials_norm = {}
        PSD_median = {}
        PSD_norm_median = {}
        freqs_cutted = None

        for phase in phase_names:
            if not trials_per_phase[phase]:
                warnings.warn(f"No trials for subject {subj_id} phase {phase}")
                continue
            min_len_phase = min([len(tr['PSD']) for tr in trials_per_phase[phase]])
            n_trials_phase = len(trials_per_phase[phase])

            trials_array = np.zeros((min_len_phase, n_trials_phase))
            trials_norm_array = np.zeros((min_len_phase, n_trials_phase))
            for i, tr in enumerate(trials_per_phase[phase]):
                trials_array[:, i] = tr['PSD'][:min_len_phase]
                trials_norm_array[:, i] = tr['PSD_norm'][:min_len_phase]

            PSD_trials[phase] = trials_array
            PSD_trials_norm[phase] = trials_norm_array
            PSD_median[phase] = np.median(trials_array, axis=1)
            PSD_norm_median[phase] = np.median(trials_norm_array, axis=1)
            freqs_cutted = subj_freqs[:min_len_phase]  # last iteration's min_len_phase is fine to use

        subj_dict['PSD_trials'] = PSD_trials
        subj_dict['PSD_trials_norm'] = PSD_trials_norm
        subj_dict['PSD_median'] = PSD_median
        subj_dict['PSD_norm_median'] = PSD_norm_median
        subj_dict['freqs_cutted'] = freqs_cutted if freqs_cutted is not None else subj_freqs

        data_dict[subj_id] = subj_dict

    return data_dict


def load_eeg_psd_connectivity_mat(mat_file: Path) -> Dict[str, Any]:
    """
    Load the EEG PSD connectivity MAT file that contains a MATLAB array EEG_PSD_ALL_CONNECTIVITY
    and convert it into a dict keyed by subject_id. Keeps PSD, PSD_norm, and trial-wise arrays.
    """
    mat_data = hdf5storage.loadmat(str(mat_file))
    EEG_PSD_ALL_CONNECTIVITY = mat_data['EEG_PSD_ALL_CONNECTIVITY']

    eeg_psd_data_dict: Dict[str, Any] = {}
    n_subjects = EEG_PSD_ALL_CONNECTIVITY.shape[1]
    for s in range(n_subjects):
        subj_struct = EEG_PSD_ALL_CONNECTIVITY[0, s]
        subj_dict: Dict[str, Any] = {
            'subject_id': subj_struct['subject_id'][0][0],
            'freqs': np.array(subj_struct['freq_axis']).flatten(),
            'PSD': np.array(subj_struct['PSD']),
            'PSD_norm': np.array(subj_struct['PSD_norm']),
            'PSD_all': np.array(subj_struct['PSD_all']),
            'PSD_norm_all': np.array(subj_struct['PSD_norm_all'])
        }
        eeg_psd_data_dict[subj_dict['subject_id']] = subj_dict
    return eeg_psd_data_dict


# ------------------------
# Utility: quick PSD sanity plot
# ------------------------
def sanity_plot_lfp_psd_pickle(pickle_file: Path, max_freq: float = 50.0) -> None:
    """
    Simple sanity check plotting of PSD normalized medians stored in the LFP PSD pickle.
    The expected structure is data_dict[subject]['freqs'] and ['PSD_norm_median'][phase].
    """
    with open(pickle_file, 'rb') as f:
        data_dict = pickle.load(f)

    subject_list = list(data_dict.keys())
    if not subject_list:
        logging.warning("No subjects found in %s", pickle_file)
        return

    n_subjects = len(subject_list)
    phase_names = list(next(iter(data_dict.values()))['PSD_norm_median'].keys())
    n_phases = len(phase_names)

    min_len = min([len(data_dict[subj]['freqs']) for subj in subject_list])
    freqs = np.array(data_dict[subject_list[0]]['freqs'])[:min_len]

    psd_all = np.zeros((min_len, n_subjects, n_phases))
    for s_idx, subj_id in enumerate(subject_list):
        for p_idx, phase in enumerate(phase_names):
            psd_phase = data_dict[subj_id]['PSD_norm_median'][phase]
            psd_all[:, s_idx, p_idx] = psd_phase[:min_len]

    psd_mean = np.mean(psd_all, axis=1)
    psd_sem = np.std(psd_all, axis=1, ddof=1) / np.sqrt(n_subjects)

    freq_mask = freqs <= max_freq
    freqs_plot = freqs[freq_mask]
    psd_mean_plot = psd_mean[freq_mask, :]
    psd_sem_plot = psd_sem[freq_mask, :]

    phase_pairs = list(combinations(range(n_phases), 2))
    n_pairs = len(phase_pairs)
    n_cols = 2
    n_rows = int(np.ceil(n_pairs / n_cols))

    plt.figure(figsize=(12, max(3, n_rows * 3)))
    colors = ['r', 'g', 'b', 'm', 'c', 'y']

    for idx, (p1, p2) in enumerate(phase_pairs):
        ax = plt.subplot(n_rows, n_cols, idx + 1)
        ax.plot(freqs_plot, psd_mean_plot[:, p1], color=colors[p1], label=phase_names[p1])
        ax.fill_between(freqs_plot,
                        psd_mean_plot[:, p1] - psd_sem_plot[:, p1],
                        psd_mean_plot[:, p1] + psd_sem_plot[:, p1],
                        color=colors[p1], alpha=0.3)
        ax.plot(freqs_plot, psd_mean_plot[:, p2], color=colors[p2], label=phase_names[p2])
        ax.fill_between(freqs_plot,
                        psd_mean_plot[:, p2] - psd_sem_plot[:, p2],
                        psd_mean_plot[:, p2] + psd_sem_plot[:, p2],
                        color=colors[p2], alpha=0.3)
        ax.set_xlabel('Frequency (Hz)')
        ax.set_ylabel('PSD (norm.)')
        ax.set_title(f'{phase_names[p1]} vs {phase_names[p2]}')
        ax.legend()
        ax.grid(False)

    plt.tight_layout()
    plt.show()


