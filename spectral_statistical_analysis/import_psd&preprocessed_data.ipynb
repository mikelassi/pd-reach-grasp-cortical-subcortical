def run_full_pipeline():
    """
    Edit base_path, subject_list, output directories and mat filenames as needed.
    """

    # === User-editable parameters ===
    base_path = Path(r'C:\Users\tomma\OneDrive - University of Pisa\Desktop\TESI\Dataset_tesi')
    subject_list = ['wue02', 'wue03', 'wue05', 'wue06', 'wue07', 'wue09', 'wue10', 'wue11']
    exclude_dict_EEG = {
        'wue05': {3: [11]},  # block 3 → trial 11
        'wue11': {1: [5]}    # block 1 → trial 5
    }

    # Where to save the aggregated pickles
    save_path = Path(r'C:\Users\tomma\OneDrive - University of Pisa\Desktop\TESI\Connectivity_Analysis\IMPORT_DATA')
    eeg_data_all: Dict[str, List[BlockDict]] = {}
    eeg_data_all_eeg2eeg: Dict[str, List[BlockDict]] = {}
    lfp_data_all: Dict[str, List[BlockDict]] = {}
    eeg_short: Dict[str, List[Dict[str, Any]]] = {}
    lfp_short: Dict[str, List[Dict[str, Any]]] = {}

    for subject_id in subject_list:
        subj_eeg_blocks, subj_eeg_blocks_EEG2EEG, subj_lfp_blocks = load_eeg_and_lfp_for_subject(base_path, subject_id, exclude_dict_EEG)

        # store results
        eeg_data_all[subject_id] = subj_eeg_blocks
        eeg_data_all_eeg2eeg[subject_id] = subj_eeg_blocks_EEG2EEG
        lfp_data_all[subject_id] = subj_lfp_blocks

        # Build short summaries
        eeg_short[subject_id] = []
